{
  "name": "radar-zone-card",
  "version": "0.1.0",
  "description": "Realtime LD2450-style radar map card for Home Assistant",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npm run build:ha",
    "build:ha": "vite build --mode ha",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"*.{json,ts}\""
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "ld2450",
    "radar"
  ],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
